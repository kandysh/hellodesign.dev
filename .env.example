# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sysdesign

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Better Auth ──────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-here-change-in-production
BETTER_AUTH_URL=http://localhost:3001

# ─── Encryption (for API key storage) ────────────────────────────────────────
# If unset, BETTER_AUTH_SECRET is used as the base key.
# Recommended: set a separate 32+ char random string.
ENCRYPTION_KEY=your-encryption-key-change-in-production

# ─── OAuth (optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── App URLs ─────────────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
