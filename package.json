{
  "name": "hellodesign-dev",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "biome format --write .",
    "check": "biome check .",
    "db:generate": "pnpm --filter @sysdesign/db db:generate",
    "db:migrate": "pnpm --filter @sysdesign/db db:migrate",
    "db:push": "pnpm --filter @sysdesign/db db:push",
    "db:studio": "pnpm --filter @sysdesign/db db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}