{
  "name": "@sysdesign/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "db:generate": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@sysdesign/config": "workspace:*",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.7.2"
  }
}
