# ── Dockerfile.web ──────────────────────────────────────────────────────────
# Build context: repo root
# Railway UI settings:
#   Dockerfile path : Dockerfile.web
#   Root directory  : / (repo root)
#   Build args      : VITE_API_URL=https://<your-api-service>.railway.app
#
# VITE_API_URL is a BUILD-TIME variable — Vite bakes it into the JS bundle.
# Set it as a build argument in Railway (not a runtime env var).

# ── Stage 1: build ────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./

COPY apps/api/package.json          ./apps/api/
COPY apps/worker/package.json       ./apps/worker/
COPY apps/web/package.json          ./apps/web/
COPY packages/ai/package.json       ./packages/ai/
COPY packages/auth/package.json     ./packages/auth/
COPY packages/config/package.json   ./packages/config/
COPY packages/db/package.json       ./packages/db/
COPY packages/queue/package.json    ./packages/queue/
COPY packages/shared/package.json   ./packages/shared/
COPY packages/types/package.json    ./packages/types/
COPY packages/ui/package.json       ./packages/ui/

RUN pnpm install --frozen-lockfile

COPY . .

# VITE_API_URL must be passed as --build-arg in Railway
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

RUN pnpm --filter @sysdesign/web build

# ── Stage 2: serve ────────────────────────────────────────────────────────────
FROM nginx:alpine AS runtime

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Copy our SPA-aware nginx template (uses $PORT injected by Railway)
COPY nginx.conf /etc/nginx/templates/default.conf.template

# Copy built static files
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

# Railway injects PORT at runtime — nginx templating substitutes it
ENV PORT=80

EXPOSE 80

# envsubst replaces $PORT in the template, then nginx starts
CMD ["/bin/sh", "-c", "envsubst '$PORT' < /etc/nginx/templates/default.conf.template > /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'"]
